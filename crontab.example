# Crontab pour CCComputer - Imports automatiques
#
# Exécute les imports SFTP et IONOS toutes les minutes
#
# Installation:
# 1. Copier ce fichier: cp crontab.example /tmp/crontab_current
# 2. Éditer pour ajuster le chemin: crontab -e
# 3. Ou utiliser: crontab crontab.example
#
# IMPORTANT: Remplacer /var/www/html par le chemin réel de votre projet

# Import SFTP - Toutes les minutes
* * * * * cd /var/www/html && /usr/bin/php scripts/import_sftp_cron.php >> /var/www/html/logs/sftp_import.log 2>&1

# Import IONOS - Toutes les minutes
* * * * * cd /var/www/html && /usr/bin/php scripts/import_ionos_cron.php >> /var/www/html/logs/ionos_import.log 2>&1

# Note: Assurez-vous que le dossier logs/ existe:
# mkdir -p /var/www/html/logs && chmod 755 /var/www/html/logs

